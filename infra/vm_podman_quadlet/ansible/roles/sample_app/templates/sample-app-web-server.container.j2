[Unit]
Description=sample-app web server container

[Container]
Image={{ web_server_image_url }}
Environment=PORT={{ web_server_port }}
PublishPort={{ web_server_port }}:{{ web_server_port }}

[Service]
Restart=always
# Extend Timeout to allow time to pull the image
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target default.target
